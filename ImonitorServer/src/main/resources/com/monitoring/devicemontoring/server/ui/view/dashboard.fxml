<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" stylesheets="@../style/styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.monitoring.devicemontoring.server.ui.controller.DashboardController">

   <!-- Sidebar -->
   <left>
      <VBox fx:id="sidebar" prefWidth="200.0" spacing="10.0" styleClass="sidebar" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Button fx:id="btnToggleSidebar" mnemonicParsing="false" onAction="#toggleSidebar" styleClass="icon-btn">
                     <graphic>
                        <FontIcon iconLiteral="fas-bars" iconSize="18" iconColor="white"/>
                     </graphic>
                  </Button>
                  <Label fx:id="lblSidebarTitle" styleClass="sidebar-label" text="DASHBOARD" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </Label>
               </children>
               <VBox.margin>
                  <Insets bottom="20.0" top="10.0" />
               </VBox.margin>
            </HBox>

            <Button fx:id="btnOverview" mnemonicParsing="false" onAction="#showOverview" styleClass="sidebar-btn" text="Overview">
               <graphic>
                  <FontIcon iconLiteral="fas-tachometer-alt" iconSize="16" styleClass="sidebar-icon"/>
               </graphic>
            </Button>
            <Button fx:id="btnClients" mnemonicParsing="false" onAction="#showClients" styleClass="sidebar-btn" text="Clients">
               <graphic>
                  <FontIcon iconLiteral="fas-desktop" iconSize="16" styleClass="sidebar-icon"/>
               </graphic>
            </Button>
            <Button fx:id="btnSettings" mnemonicParsing="false" onAction="#showSettings" styleClass="sidebar-btn" text="Settings">
               <graphic>
                  <FontIcon iconLiteral="fas-cog" iconSize="16" styleClass="sidebar-icon"/>
               </graphic>
            </Button>
            <Button fx:id="btnLogs" mnemonicParsing="false" onAction="#showLogs" styleClass="sidebar-btn" text="Logs">
               <graphic>
                  <FontIcon iconLiteral="fas-file-alt" iconSize="16" styleClass="sidebar-icon"/>
               </graphic>
            </Button>
         </children>
      </VBox>
   </left>

   <!-- Main Content -->
   <center>
      <StackPane fx:id="contentPane" BorderPane.alignment="CENTER">
         <children>
            <!-- Overview View -->
            <VBox fx:id="viewOverview" spacing="20.0" style="-fx-background-color: #f4f6f8;">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="20.0">
                     <children>
                        <Label fx:id="lblPageTitle" text="System Overview" textFill="#2c3e50">
                           <font>
                              <Font name="System Bold" size="24.0" />
                           </font>
                        </Label>
                        <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                           <children>
                              <Label text="Server IP: " textFill="#7f8c8d">
                                 <font>
                                    <Font size="14.0" />
                                 </font>
                              </Label>
                              <Label fx:id="lblServerIp" text="Loading..." textFill="#2980b9">
                                 <font>
                                    <Font name="System Bold" size="14.0" />
                                 </font>
                              </Label>
                           </children>
                        </HBox>
                     </children>
                  </HBox>

                  <!-- Analytics Cards -->
                  <HBox fx:id="analyticsBox" spacing="20.0">
                     <children>
                        <VBox prefWidth="200.0" styleClass="card">
                           <children>
                              <HBox alignment="CENTER_LEFT" spacing="10.0">
                                 <children>
                                    <FontIcon iconLiteral="fas-users" iconSize="24" iconColor="#2980b9"/>
                                    <VBox>
                                       <Label text="Connected Clients" textFill="#7f8c8d" />
                                       <Label fx:id="lblTotalClients" text="0" textFill="#2980b9">
                                          <font>
                                             <Font name="System Bold" size="28.0" />
                                          </font>
                                       </Label>
                                    </VBox>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                        <VBox prefWidth="200.0" styleClass="card">
                           <children>
                              <HBox alignment="CENTER_LEFT" spacing="10.0">
                                 <children>
                                    <FontIcon iconLiteral="fas-microchip" iconSize="24" iconColor="#e67e22"/>
                                    <VBox>
                                       <Label text="Avg CPU Load" textFill="#7f8c8d" />
                                       <Label fx:id="lblAvgCpu" text="0.0 %" textFill="#e67e22">
                                          <font>
                                             <Font name="System Bold" size="28.0" />
                                          </font>
                                       </Label>
                                    </VBox>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                        <VBox prefWidth="200.0" styleClass="card">
                           <children>
                              <HBox alignment="CENTER_LEFT" spacing="10.0">
                                 <children>
                                    <FontIcon iconLiteral="fas-memory" iconSize="24" iconColor="#8e44ad"/>
                                    <VBox>
                                       <Label text="Avg RAM Usage" textFill="#7f8c8d" />
                                       <Label fx:id="lblAvgRam" text="0.0 %" textFill="#8e44ad">
                                          <font>
                                             <Font name="System Bold" size="28.0" />
                                          </font>
                                       </Label>
                                    </VBox>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                        <VBox prefWidth="200.0" styleClass="card">
                           <children>
                              <HBox alignment="CENTER_LEFT" spacing="10.0">
                                 <children>
                                    <FontIcon iconLiteral="fas-network-wired" iconSize="24" iconColor="#27ae60"/>
                                    <VBox>
                                       <Label text="Total Network" textFill="#7f8c8d" />
                                       <Label fx:id="lblTotalNetwork" text="0 KB/s" textFill="#27ae60">
                                          <font>
                                             <Font name="System Bold" size="20.0" />
                                          </font>
                                       </Label>
                                    </VBox>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </children>
                  </HBox>

                  <!-- Charts and Table -->
                  <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                     <children>
                        <!-- Client Table -->
                        <VBox styleClass="card" HBox.hgrow="ALWAYS">
                           <children>
                              <Label styleClass="card-title" text="Active Clients">
                                 <VBox.margin>
                                    <Insets bottom="10.0" />
                                 </VBox.margin>
                              </Label>
                              <TableView fx:id="clientTable" VBox.vgrow="ALWAYS">
                                <columns>
                                  <TableColumn fx:id="colHostname" prefWidth="120.0" text="Hostname" />
                                  <TableColumn fx:id="colIp" prefWidth="110.0" text="IP Address" />
                                    <TableColumn fx:id="colOs" prefWidth="100.0" text="OS" />
                                    <TableColumn fx:id="colCpu" prefWidth="90.0" text="CPU" />
                                    <TableColumn fx:id="colRam" prefWidth="110.0" text="RAM" />
                                    <TableColumn fx:id="colNet" prefWidth="140.0" text="Network" />
                                </columns>
                              </TableView>
                           </children>
                        </VBox>

                        <!-- CPU Chart -->
                        <VBox fx:id="chartBox" prefWidth="350.0" styleClass="card">
                           <children>
                              <Label styleClass="card-title" text="Live CPU Load">
                                 <VBox.margin>
                                    <Insets bottom="10.0" />
                                 </VBox.margin>
                              </Label>
                              <BarChart fx:id="cpuChart" legendVisible="false" VBox.vgrow="ALWAYS">
                                <xAxis>
                                  <CategoryAxis label="Client" side="BOTTOM" />
                                </xAxis>
                                <yAxis>
                                  <NumberAxis label="Load %" side="LEFT" upperBound="100.0" />
                                </yAxis>
                              </BarChart>
                           </children>
                        </VBox>
                     </children>
                  </HBox>
               </children>
            </VBox>

            <!-- Settings View -->
            <VBox fx:id="viewSettings" spacing="20.0" style="-fx-background-color: #f4f6f8;" visible="false">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
               <children>
                  <Label text="Settings" textFill="#2c3e50">
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                  </Label>
                  <VBox maxWidth="600.0" spacing="15.0" styleClass="card">
                     <children>
                        <Label styleClass="card-title" text="Server Configuration" />
                        <VBox spacing="5.0">
                           <Label text="Server Port (RMI)" textFill="#7f8c8d" />
                           <TextField text="1099" />
                        </VBox>
                        <VBox spacing="5.0">
                           <Label text="Refresh Interval (Seconds)" textFill="#7f8c8d" />
                           <TextField text="5" />
                        </VBox>
                        <CheckBox mnemonicParsing="false" selected="true" text="Enable Auto-Discovery" />
                        <CheckBox mnemonicParsing="false" selected="true" text="Log Client Connections" />
                        <Button mnemonicParsing="false" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="Save Changes" />
                     </children>
                  </VBox>
               </children>
            </VBox>

            <!-- Logs View -->
            <VBox fx:id="viewLogs" spacing="20.0" style="-fx-background-color: #f4f6f8;" visible="false">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
               <children>
                  <Label text="System Logs" textFill="#2c3e50">
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                  </Label>
                  <VBox styleClass="card" VBox.vgrow="ALWAYS">
                     <children>
                        <TextArea fx:id="txtLogs" editable="false" VBox.vgrow="ALWAYS">
                           <font>
                              <Font name="Consolas" size="14.0" />
                           </font>
                        </TextArea>
                     </children>
                  </VBox>
               </children>
            </VBox>
         </children>
      </StackPane>
   </center>
</BorderPane>
